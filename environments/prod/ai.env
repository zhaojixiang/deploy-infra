NODE_ENV=production
# 若宿主机 80 已被占用，改为 8080 等；健康检查会跟随此端口（勿再单独写死 EDGE_*）
PUBLIC_HTTP_PORT=80

# 浏览器实际访问的站点根（含协议）；用 IP 部署时写成 http://118.24.52.67 等，勿留占位域名
PUBLIC_BASE_URL=https://your-domain.example.com
# 与上一致或 *；跨域场景下须包含前端 Origin
CORS_ORIGIN=https://your-domain.example.com

# 生产：DB_SYNC=false 走迁移；强口令建议放在 projects/ai/.env.local
DB_NAME=ai_prod
DB_SYNC=false
