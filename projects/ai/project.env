# Non-secret defaults (override per environment in environments/<env>/ai.env)
COMPOSE_PROJECT_NAME=ai-stack

REGISTRY=crpi-3iew34pvm0fklze5.cn-chengdu.personal.cr.aliyuncs.com
NAMESPACE=jijiking1

# Initial image tags — set to the same real tag before first pull (never use latest)
TAG_FRONTEND_BLUE=20260409-7ce4a6c
TAG_FRONTEND_GREEN=20260409-7ce4a6c
TAG_BACKEND_BLUE=20260409-c874389
TAG_BACKEND_GREEN=20260409-c874389

PUBLIC_HTTP_PORT=80

# MySQL / Redis（与 ai-backend 配置一致；mysql 服务用 DB_* 初始化库账号）
MYSQL_ROOT_PASSWORD=localroot
DB_HOST=mysql
DB_PORT=3306
DB_USER=ai
DB_PASSWORD=aipass
DB_NAME=ai
DB_SYNC=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
